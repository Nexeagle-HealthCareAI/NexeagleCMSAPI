{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "<set-in-Azure-App-Service-ConnectionStrings-DefaultConnection>"
  },
  "TokenSettings": {
    "Issuer": "<set-in-Azure-App-Service-ConnectionStrings-DefaultConnection>",
    "Audience": "<set-in-Azure-App-Service-ConnectionStrings-DefaultConnection>",
    "Key": "<set-in-Azure-App-Service-ConnectionStrings-DefaultConnection>",
    "ExpiresInMinutes": 15
  }
}